# Elasticsearch
ES_VERSION=8.17.0
ES_JAVA_OPTS=-Xms1g -Xmx1g
ES_CLUSTER_NAME=labrador-maison
ES_NODE_NAME=es-node-1
ES_MEM_LIMIT=2g

# Kibana
KIBANA_VERSION=8.17.0

# Elastic Agent
AGENT_VERSION=8.17.0

# OTLP ingestion ports (exposed on host for external apps)
OTLP_HTTP_PORT=8201
OTLP_GRPC_PORT=8200

# Timezone
TZ=America/Toronto

# --- Secrets (generated by scripts/setup.sh, stored in .secrets.env) ---
# ELASTIC_PASSWORD=
# KIBANA_ENCRYPTION_KEY=
# ES_BASIC_AUTH=
