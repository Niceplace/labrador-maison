# Necessary for worker P2P
CONCOURSE_BAGGAGECLAIM_BIND_IP=0.0.0.0

# avoid using loopbacks
CONCOURSE_BAGGAGECLAIM_DRIVER=overlay

# work with docker-compose's dns
CONCOURSE_CONTAINERD_DNS_PROXY_ENABLE=true

# Two options to configure the worked to talk back to the web node
#  Internal means it's on the same docker-compose stack and same server
#  External means it's deployed on a different host, so it needs to use DNS to connect to web
CONCOURSE_TSA_HOST_INTERNAL=concourse-web:2222
CONCOURSE_TSA_HOST_EXTERNAL=thinkcenter.dev:2222

CONCOURSE_RUNTIME=containerd

CONCOURSE_TSA_PUBLIC_KEY=/concourse-keys/tsa_host_key.pub
CONCOURSE_TSA_WORKER_PRIVATE_KEY=/concourse-keys/worker_key
